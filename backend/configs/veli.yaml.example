# Veḷi backend configuration.
# Copy to configs/veli.yaml and adjust for your environment.
# Environment variables (VELI_*) override values set here.

server:
  listen: ":8080"
  read_timeout: 30s
  write_timeout: 30s
  shutdown_timeout: 15s

database:
  dsn: "postgres://veli:veli@localhost:5432/veli?sslmode=disable"
  max_open_conns: 25
  max_idle_conns: 5
  conn_max_lifetime: 5m
  auto_migrate: false

auth:
  jwt_secret: "CHANGE-ME-IN-PRODUCTION"
  token_expiry: 24h
  allowed_origins:
    - "http://localhost:5173"
  frontend_url: "http://localhost:5173"

observability:
  log_level: "info"   # debug | info | warn | error
  log_format: "json"  # json | text
