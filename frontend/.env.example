# Veḷi frontend — local environment overrides.
# Copy to frontend/.env. SvelteKit reads this automatically.
#
# All variables are server-only ($env/dynamic/private) — never prefix
# with PUBLIC_ unless you explicitly want browser exposure. The
# backend URL must stay private so the browser can't bypass SSR.

# Base URL of the Veḷi REST API. In dev this is the Go backend on :8080.
VELI_API_BASE_URL=http://localhost:8080
