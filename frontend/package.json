{
	"name": "veli-frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"cap:sync": "pnpm run build && cap sync",
		"cap:android": "JAVA_HOME=$JAVA_HOME pnpm run build && cap sync android && cap open android",
		"cap:run:android": "JAVA_HOME=$JAVA_HOME pnpm run build && cap sync android && cap run android",
		"cap:dev:android": "CAPACITOR_LIVE_RELOAD=1 cap sync android && cap run android"
	},
	"devDependencies": {
		"@capacitor/cli": "^8.3.0",
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.4",
		"@inlang/paraglide-js": "^2.15.1",
		"@lucide/svelte": "^1.7.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24.12.0",
		"bits-ui": "^2.16.4",
		"clsx": "^2.1.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^16.5.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^8.0.3",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"@capacitor/android": "^8.3.0",
		"@capacitor/core": "^8.3.0",
		"@capacitor/preferences": "^8.0.1",
		"@capacitor/splash-screen": "^8.0.1",
		"@capacitor/status-bar": "^8.0.2"
	}
}
