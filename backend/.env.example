# Veḷi backend — local environment overrides.
# Copy to backend/.env. The Makefile sources this file for migration commands.

# Database connection used by `make migrations/*` (without the postgres:// prefix).
DB_DSN=veli:veli@localhost:5432/veli?sslmode=disable

# Override config.yaml at runtime (optional).
VELI_LISTEN=:8080
VELI_DATABASE_AUTOMIGRATE=false
VELI_LOG_LEVEL=info
VELI_LOG_FORMAT=text

# Auth — generate real secrets before any deploy.
VELI_AUTH_JWT_SECRET=replace-me
VELI_AUTH_FRONTEND_URL=http://localhost:5173
VELI_AUTH_ALLOWED_ORIGINS=http://localhost:5173

# Dev-mode trusts the X-User-ID header as the actor. NEVER enable in production.
VELI_AUTH_DEVMODE=false

# Session cookie HMAC key. 32+ bytes of high-entropy data (e.g.
# `openssl rand -hex 32`). Empty disables signed sessions, which
# means Google sign-in can't issue a session cookie.
VELI_AUTH_SESSION_SECRET=

# Google OIDC client (admin auth path). Empty CLIENT_ID disables
# the routes (they return 503). Provision in Google Cloud Console;
# add the redirect URL to the OAuth client's authorised redirect URIs.
VELI_AUTH_GOOGLE_CLIENT_ID=
VELI_AUTH_GOOGLE_CLIENT_SECRET=
VELI_AUTH_GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback
